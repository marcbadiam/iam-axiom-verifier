# ==========================================
# IAM Axiom Verifier - Environment Config
# ==========================================

# 1. Choose your LLM Provider ("gemini" or "openai")
LLM_PROVIDER="gemini"

# 2. Provide the corresponding API Key
# If you chose "gemini" above:
GEMINI_API_KEY="AIzaSy-Your-Gemini-Key-Here..."

# If you chose "openai" above:
OPENAI_API_KEY="sk-proj-Your-OpenAI-Key-Here..."

# If you have your API KEY set in some environment variable, 
# you can put something like:
# GEMINI_API_KEY=${MY_GEMINI_API_KEY}

# 3. Force Mock Mode (Air-Gapped deterministic testing)
# Change to "false" when you want to use the real APIs
USE_MOCK_LLM="true"