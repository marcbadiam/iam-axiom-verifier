# ==========================================
# IAM Axiom Verifier - Environment Config
# ==========================================

# 1. Which environment variable holds your LLM API Key? 
# (Defaults to OPENAI_API_KEY, but you can override it here for enterprise environments)
LLM_API_KEY_VAR_NAME="OPENAI_API_KEY"


# 2. Force Mock Mode (Air-Gapped deterministic testing)
# Change to "false" when you want to use the real API
USE_MOCK_LLM="true"