{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowProvisionEC2",
            "Effect": "Allow",
            "Action": [
                "ec2:RunInstances"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "ec2:InstanceType": ["p4d.24xlarge", "p3dn.24xlarge"]
                }
            }
        }
    ]
}
