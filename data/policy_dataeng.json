{
    "RoleName": "DataScience-SageMaker-Execution",
    "PolicyName": "DataScience-Core-Policy",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Sid": "AllowGPUTraining",
                "Effect": "Allow",
                "Action": ["ec2:RunInstances", "sagemaker:CreateTrainingJob"],
                "Resource": "*"
            },
            {
                "Sid": "ReadDataLake",
                "Effect": "Allow",
                "Action": ["s3:GetObject", "s3:ListBucket"],
                "Resource": "arn:aws:s3:::corp-data-lake-prod/*"
            }
        ]
    }
}
