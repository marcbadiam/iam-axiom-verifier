{
  "RoleName": "DataEng-Team",
  "PolicyDocument": {
    "Statement": [
      {
        "Sid": "AllowOnlyGPUInstances",
        "Effect": "Allow",
        "Action": ["ec2:RunInstances"],
        "Resource": "*",
        "Condition": {
          "StringEquals": {
            "ec2:InstanceType": ["p4d.24xlarge", "g5.48xlarge"]
          }
        }
      }
    ]
  }
}
