{
  "RoleName": "DataEng-Team",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBroadEC2",
      "Effect": "Allow",
      "Action": ["ec2:RunInstances", "ec2:DescribeInstances", "ec2:TerminateInstances"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": ["us-east-1", "eu-west-1"],
          "ec2:InstanceType": ["t3.micro", "m5.large", "p4d.24xlarge", "g5.48xlarge"]
        }
      }
    },
    {
      "Sid": "AllowRDSAll",
      "Effect": "Allow",
      "Action": ["rds:*"],
      "Resource": "*"
    },
    {
      "Sid": "AllowS3Full",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": "*"
    }
  ]
}
